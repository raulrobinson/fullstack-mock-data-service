    { "key": "notFoundId", "value": "999999" },
    {
      "key": "sqlScript",
      "value": "INSERT INTO user_mocks (name, description, created_at, updated_at) VALUES ('postman-sql-user', 'created by postman', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP);"
    }
  ],
  "item": [
    {
      "name": "00 - Health",
      "item": [
        {
          "name": "GET /actuator/health",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Source-Bank", "value": "{{sourceBank}}" },
              { "key": "Application-Id", "value": "{{applicationId}}" }
            ],
            "url": "{{baseUrl}}/actuator/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - User Mocks - Happy Path",
      "item": [
        {
          "name": "GET /api/user-mocks (list)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Source-Bank", "value": "{{sourceBank}}" },
              { "key": "Application-Id", "value": "{{applicationId}}" }
            ],
            "url": "{{baseUrl}}/api/user-mocks"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Tiene estructura esperada', function () {",
                  "  pm.expect(body).to.have.property('items');",
                  "  pm.expect(body).to.have.property('count');",
                  "  pm.expect(body).to.have.property('runtime');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/user-mocks (create)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Source-Bank", "value": "{{sourceBank}}" },
              { "key": "Application-Id", "value": "{{applicationId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"postman-created-user\",\n  \"description\": \"usuario creado desde postman\"\n}"
            },
            "url": "{{baseUrl}}/api/user-mocks"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('createdId', String(body.id));",
                  "pm.test('Guarda createdId para pruebas siguientes', function () {",
                  "  pm.expect(pm.collectionVariables.get('createdId')).to.match(/^\\d+$/);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/user-mocks/{id} (get by id)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Source-Bank", "value": "{{sourceBank}}" },
              { "key": "Application-Id", "value": "{{applicationId}}" }
            ],
            "url": "{{baseUrl}}/api/user-mocks/{{createdId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Retorna el id esperado', function () {",
                  "  pm.expect(String(body.id)).to.eql(pm.collectionVariables.get('createdId'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT /api/user-mocks/{id} (update)",
