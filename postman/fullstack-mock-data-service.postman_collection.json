            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"postman-updated-user\",\n  \"description\": \"usuario actualizado desde postman\"\n}"
            },
            "url": "{{baseUrl}}/api/user-mocks/{{createdId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
