        "exec": [
          "if (!pm.collectionVariables.get('createdId')) {",
          "  pm.collectionVariables.set('createdId', '1');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "bearerToken", "value": "mock-token" },
